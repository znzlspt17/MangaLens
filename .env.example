# DeepL API
DEEPL_API_KEY=your_deepl_api_key_here

# Google Translation (대체)
GOOGLE_API_KEY=

# GPU 설정 (auto | cuda | rocm | cpu)
GPU_BACKEND=auto

# 서버 설정
MAX_UPLOAD_SIZE=52428800
MAX_CONCURRENT_TASKS=1
RESULT_TTL_SECONDS=3600
DELETE_AFTER_DOWNLOAD=false
# 브라우저에서 다른 출처 프론트엔드를 붙일 때만 명시적으로 설정
# 예: ALLOWED_ORIGINS=https://mangalens.example.com
ALLOWED_ORIGINS=
SKIP_WARMUP=false

# 모델/폰트 캐시 경로
MODEL_CACHE_DIR=./models
FONT_DIR=./fonts
